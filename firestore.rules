rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // "Dueño" pleno de su empresa (tenant): rol explícito 'admin', o legado
    // (docs de antes del refactor multi-tenant, sin campo 'rol' ni 'permisos').
    function isSuperAdmin() {
      let d = get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
      return (d.rol == 'admin') || (!('rol' in d) && !('permisos' in d));
    }

    // Super Admin de la PLATAFORMA (dueño del SaaS, ve/gestiona todas las empresas).
    // Colección separada de 'admins' para no mezclar el rol de plataforma con el de tenant.
    function isPlatformSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // Datos del doc admins/{uid} del que llama (solo válido si isAdmin() es true).
    function callerAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    // La empresa está activa (no suspendida). Una empresa suspendida pierde acceso a sus datos
    // de inmediato, aunque su sesión siga vigente — no basta con ocultar el botón en el panel.
    function tenantActiva(tenantId) {
      return get(/databases/$(database)/documents/empresas/$(tenantId)).data.estado == 'activa';
    }

    // Admin/miembro cuyo tenantId coincide con el del recurso, de una empresa activa —
    // el corazón del aislamiento multi-tenant.
    function isAdminOfTenant(tenantId) {
      return isAdmin() && callerAdminData().tenantId == tenantId && tenantActiva(tenantId);
    }

    // Un miembro puede tener acceso restringido a solo algunos talleres (tallerIds: [...]).
    // tallerIds == null significa acceso a todos los talleres del tenant (el dueño siempre lo tiene).
    function hasTallerAccess(tallerId) {
      let ids = callerAdminData().tallerIds;
      return ids == null || (tallerId in ids);
    }

    function getTallerId() {
      return get(/databases/$(database)/documents/tallerUsuarios/$(request.auth.uid)).data.tallerId;
    }

    function isTallerMember(tallerId) {
      return request.auth != null && (
        request.auth.uid == tallerId ||
        (exists(/databases/$(database)/documents/tallerUsuarios/$(request.auth.uid)) &&
         getTallerId() == tallerId)
      );
    }

    // Empresas (tenants): gestión reservada al Super Admin de plataforma.
    // La creación/activación/suspensión se hace por Cloud Functions (Admin SDK, ignora estas reglas);
    // aquí solo se habilita la lectura para el panel de Super Admin.
    match /empresas/{tenantId} {
      allow read: if isPlatformSuperAdmin() || (isAdmin() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.tenantId == tenantId);
      allow write: if false;
    }

    // Super Admins de plataforma: doc marcador, gestionado manualmente/por migración. Solo lectura propia.
    match /superadmins/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Admins: cualquier usuario autenticado puede leer su PROPIO doc (para verificar rol en login).
    // La creación ahora es EXCLUSIVA de las Cloud Functions (crearEmpresa/crearMiembroEquipo),
    // que usan el Admin SDK y por lo tanto no pasan por estas reglas: allow create queda cerrado.
    match /admins/{uid} {
      allow read:   if request.auth != null &&
        (isAdminOfTenant(resource.data.tenantId) || request.auth.uid == uid || isPlatformSuperAdmin());
      allow create: if false;
      allow update: if request.auth.uid == uid ||
        (isAdminOfTenant(resource.data.tenantId) && isSuperAdmin());
      allow delete: if isAdminOfTenant(resource.data.tenantId) && isSuperAdmin() && request.auth.uid != uid;
    }

    // Talleres: cualquier usuario autenticado puede leer su PROPIO doc (para verificar rol en login).
    // La creación es exclusiva de la Cloud Function crearTallerCF.
    match /talleres/{uid} {
      allow read:   if request.auth != null &&
        ((isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(uid)) || isTallerMember(uid) || request.auth.uid == uid || isPlatformSuperAdmin());
      allow create: if false;
      allow update, delete: if isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(uid);
    }

    // Sub-usuarios: pueden leer su propio doc (para obtener tallerId en login).
    // La creación es exclusiva de la Cloud Function crearTallerUsuarioCF.
    match /tallerUsuarios/{uid} {
      allow read:   if (isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId)) || (request.auth != null && request.auth.uid == uid) || isPlatformSuperAdmin();
      allow create: if false;
      allow update: if (isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId)) || (request.auth != null && request.auth.uid == uid);
      allow delete: if isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId);
    }

    match /config/counters {
      allow read, write: if request.auth != null;
    }

    match /pedidos/{pedidoId} {
      allow read:   if (isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId)) || (isTallerMember(resource.data.tallerId) && tenantActiva(resource.data.tenantId)) || isPlatformSuperAdmin();
      allow create: if (isAdminOfTenant(request.resource.data.tenantId) && hasTallerAccess(request.resource.data.tallerId)) || (isTallerMember(request.resource.data.tallerId) && tenantActiva(request.resource.data.tenantId));
      allow update: if (isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId)) || (isTallerMember(resource.data.tallerId) && tenantActiva(resource.data.tenantId));
      allow delete: if isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId);
    }

    match /facturas/{facturaId} {
      allow read:   if (isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId)) || (isTallerMember(resource.data.tallerId) && tenantActiva(resource.data.tenantId)) || isPlatformSuperAdmin();
      allow create: if isAdminOfTenant(request.resource.data.tenantId) && hasTallerAccess(request.resource.data.tallerId);
      allow update: if isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId);
      allow delete: if isAdminOfTenant(resource.data.tenantId) && hasTallerAccess(resource.data.tallerId);
    }

    // Backups de facturas: solo el superadmin puede crear, leer, restaurar o borrar.
    match /facturaBackups/{backupId} {
      allow read, create, update, delete: if isAdmin() && isSuperAdmin();

      match /items/{itemId} {
        allow read, create, update, delete: if isAdmin() && isSuperAdmin();
      }
    }

    // Tokens FCM: clave = token sanitizado; el uid en el doc debe coincidir
    match /fcmTokens/{tokenId} {
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, delete:   if request.auth != null && resource.data.uid == request.auth.uid;
    }

  }
}
