rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      let d = get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
      return !('permisos' in d);
    }

    // Admins: cualquier admin puede leer (para listar equipo);
    // solo superadmin puede crear/eliminar; admin puede actualizarse a sí mismo
    match /admins/{uid} {
      allow read:   if isAdmin();
      allow create: if isAdmin() && isSuperAdmin();
      allow update: if isAdmin() && (isSuperAdmin() || request.auth.uid == uid);
      allow delete: if isAdmin() && isSuperAdmin() && request.auth.uid != uid;
    }

    // Talleres: admin lee/escribe todos; taller lee solo el suyo
    match /talleres/{uid} {
      allow read:  if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    // Contador de folios
    match /config/counters {
      allow read, write: if request.auth != null;
    }

    // Pedidos: admin lee/escribe todos; taller lee/escribe solo los suyos
    match /pedidos/{pedidoId} {
      allow read:   if isAdmin() || (request.auth != null && resource.data.tallerId == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.tallerId == request.auth.uid);
      allow update: if isAdmin() || (request.auth != null && resource.data.tallerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Facturas: admin lee/escribe todas; taller solo lee las suyas
    match /facturas/{facturaId} {
      allow read:   if isAdmin() || (request.auth != null && resource.data.tallerId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
